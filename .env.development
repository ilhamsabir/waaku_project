# Development Environment Variables
NODE_ENV=development
PORT=4300

# Vite Development Server
VITE_PORT=1100
VITE_HOST=0.0.0.0

# API Base URL for frontend development
VITE_API_BASE_URL=http://localhost:4300

# Debug mode
DEBUG=whatsapp-web.js:*


# UUID4 + SHA-512 API Key System
# Raw UUID4 (for client X-API-Key header)
VITE_API_KEY=xxxx
# SHA-512 hash of UUID4 (for server validation)
WAAKU_API_KEY=xxxxx
